{
  "name": "plantasia-sound-engine",
  "version": "0.1.0",
  "description": "Reusable botanical synthesis engine for Plantasia applications",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "presets",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "sync-presets": "node scripts/sync-presets.mjs",
    "build": "tsc -p tsconfig.json",
    "postbuild": "cp -r src/presets/bundled dist/presets/bundled",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "npm run clean && npm run sync-presets",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "vite --config vite.config.ts",
    "demo": "vite --config vite.demo.config.ts",
    "example:basic": "EXAMPLE_DIR=examples/basic vite --config vite.example.config.ts",
    "example:presets": "EXAMPLE_DIR=examples/presets vite --config vite.example.config.ts",
    "example:effects": "EXAMPLE_DIR=examples/effects vite --config vite.example.config.ts",
    "example:midi": "EXAMPLE_DIR=examples/midi vite --config vite.example.config.ts",
    "example:sequencing": "EXAMPLE_DIR=examples/sequencing vite --config vite.example.config.ts",
    "example:generative": "EXAMPLE_DIR=examples/generative vite --config vite.example.config.ts"
  },
  "keywords": [
    "audio",
    "synthesis",
    "tonejs",
    "plantasia",
    "botanical",
    "web-audio"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "license": "MIT"
}
